   "source": [
    "def howmuch(a,b=100):\n",
    "\n",
    "    count=0\n",
    "    for i in range (1, b):\n",
    "        if i % a == 0:\n",
    "            count = count + 1\n",
    "    return count\n",
    "print(howmuch(7,))\n"
